{
  "name": "gojira",
  "version": "1.8.0",
  "description": "Extract Jira issues and control-chart durations into CSV, JSON, Markdown or HTML reports",
  "main": "index.js",
  "bin": {
    "gojira": "bin/gojira"
  },
  "files": [
    "index.js",
    "bin/",
    "lib/",
    "project_config.json.default",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "jira",
    "agile",
    "cycle-time",
    "lead-time",
    "control-chart",
    "metrics",
    "csv",
    "report"
  ],
  "scripts": {
    "test": "mocha --recursive spec/mocha",
    "lint": "eslint .",
    "coverage": "istanbul cover -x \"spec/**\" node_modules/mocha/bin/_mocha -- --recursive spec/mocha",
    "coverage:check": "istanbul check-coverage --statements 90 --branches 85 --functions 90 --lines 90",
    "demo": "node scripts/generate_demo.js"
  },
  "repository": {
    "type": "git",
    "url": "http://github.com/helmedeiros/gojira.git"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=4"
  },
  "dependencies": {
    "axios": "^0.7.0",
    "commander": "^2.9.0"
  },
  "devDependencies": {
    "chai": "^3.5.0",
    "eslint": "^1.10.3",
    "istanbul": "^0.4.2",
    "mocha": "^2.4.5",
    "sinon": "^1.17.3"
  }
}
